{
  "name": "level-up-vnext",
  "version": "4.1.3",
  "description": "Microsoft Edge sidebar extension for Dynamics 365/Power Apps productivity tools",
  "main": "build/background.js",
  "type": "module",
  "imports": {
    "#types/*": "./src/types/*",
    "#services/*": "./src/services/*",
    "#components/*": "./src/sidebar/components/*",
    "#contexts/*": "./src/sidebar/contexts/*",
    "#hooks/*": "./src/sidebar/hooks/*",
    "#config/*": "./src/sidebar/config/*",
    "#utils/*": "./src/utils/*",
    "#content/*": "./src/content/*",
    "#background/*": "./src/background/*",
    "#data/*": "./src/data/*"
  },
  "scripts": {
    "build": "vite build --mode production",
    "build:dev": "cross-env NODE_ENV=development vite build",
    "dev": "cross-env NODE_ENV=development vite build --watch",
    "watch": "vite build --mode production --watch",
    "clean": "rimraf build release",
    "pack": "npm run clean && npm run build && node scripts/package.js",
    "pack:dev": "npm run clean && cross-env NODE_ENV=development vite build && node scripts/package.js",
    "pack:firefox": "npm run clean && npm run build && node scripts/package.js firefox",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css,html}\"",
    "code-quality": "npm run lint && npm run format:check && npm run type-check",
    "code-quality:fix": "npm run lint:fix && npm run format",
    "type-check": "tsc --noEmit",
    "pre-commit": "npm run code-quality:fix && npm run build",
    "validate": "npm run code-quality && npm run build",
    "size": "npm run build && node -e \"const fs=require('fs'); const files=['sidebar.js','levelup-extension.js','background.js']; files.forEach(f => { try { const stats = fs.statSync('build/'+f); console.log(f + ': ' + (stats.size/1024).toFixed(2) + ' KB'); } catch(e) { console.log(f + ': not found'); } });\"",
    "bundle-analyze": "npx vite-bundle-analyzer build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "bump": "node scripts/bump-version.js",
    "tag": "node -e \"const v=require('./package.json').version; require('child_process').execSync(`git tag v${v} && git push origin v${v}`, {stdio:'inherit'})\"",
    "tag:check": "node -p \"require('./package.json').version\"",
    "update-release-notes": "node scripts/update-release-notes.js"
  },
  "keywords": [
    "dynamics-365",
    "browser-extension",
    "sidebar",
    "productivity",
    "power-apps"
  ],
  "author": "Natraj Yegnaraman",
  "homepage": "https://github.com/rajyraman/Levelup-for-Dynamics-CRM",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/xrm": "^9.0.94",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "archiver": "^8.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@playwright/test": "^1.60.0",
    "@uiw/react-codemirror": "^4.25.10",
    "dynamics-web-api": "^2.5.0",
    "otplib": "^13.4.1",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
